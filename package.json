{
  "name": "memory-alpha",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "id": "memory-alpha",
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "setup": "node dist/setup.js",
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:pull-model": "docker exec memory-alpha-ollama ollama pull snowflake-arctic-embed2",
    "cleanup": "node dist/cleanup.js"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "sqlite3": "^5.1.7",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/prompts": "^2.4.9",
    "@types/sqlite3": "^3.1.11",
    "typescript": "^5.9.3"
  }
}
