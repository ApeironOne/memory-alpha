{
  "id": "memory-alpha",
  "name": "Memory Alpha",
  "description": "Universal memory system with SQLite keyword search and optional Qdrant vector search for OpenClaw agents",
  "version": "0.4.0",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "sqlitePath": { "type": "string" },
      "qdrantUrl": { "type": "string", "optional": true },
      "qdrantCollection": { "type": "string", "optional": true },
      "ollamaUrl": { "type": "string", "optional": true },
      "embedModel": { "type": "string", "optional": true },
      "embedDimensions": { "type": "number", "optional": true },
      "autoCapture": { "type": "boolean", "default": true },
      "autoRecall": { "type": "boolean", "default": true },
      "recallLimit": { "type": "number", "default": 10 },
      "captureMode": { "type": "string", "enum": ["filtered", "full", "hybrid"], "default": "hybrid" },
      "sharedPool": { "type": "boolean", "default": false }
    }
  }
}
